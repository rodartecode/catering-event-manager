# =============================================================================
# GO SCHEDULING SERVICE ENVIRONMENT
# =============================================================================
# Copy this file to .env and fill in your actual values
# This service handles high-performance resource conflict detection

# =============================================================================
# DATABASE (required)
# =============================================================================
# PostgreSQL connection string (shared with Next.js app)
DATABASE_URL="postgresql://admin:changeme@localhost:5432/catering_events"

# =============================================================================
# HTTP SERVER
# =============================================================================
# Port for Fiber web server to listen on
# Must match SCHEDULING_SERVICE_URL in Next.js app (default: 8080)
PORT=8080

# =============================================================================
# LOGGING
# =============================================================================
# Log level for structured JSON logging
# Options: debug, info, warn, error (default: info)
LOG_LEVEL="info"

# =============================================================================
# CORS & SECURITY
# =============================================================================
# Allowed origins for CORS (Next.js app URL)
# Default: http://localhost:3000
ALLOWED_ORIGINS="http://localhost:3000"
