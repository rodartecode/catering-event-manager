{
  "git": {
    "deploymentEnabled": false
  },
  "buildCommand": "cd ../.. && pnpm build --filter=@catering-event-manager/web",
  "installCommand": "cd ../.. && pnpm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/cron/follow-ups", "schedule": "0 9 * * *" },
    { "path": "/api/cron/notifications-digest", "schedule": "0 8,14,20 * * *" }
  ]
}
